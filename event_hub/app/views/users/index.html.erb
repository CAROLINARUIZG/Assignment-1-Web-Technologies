<h1 class="mb-4">Users</h1>
<table class="table table-striped">
  <thead><tr><th>Name</th><th>Email</th><th>Role</th></tr></thead>
  <tbody>
    <% @users.each do |u| %>
      <tr>
        <td><%= link_to u.name, user_path(u) %></td>
        <td><%= u.email %></td>
        <td>
          <span class="badge bg-<%= u.admin? ? 'danger' : 'secondary' %>">
            <%= u.role.titleize %>
          </span>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>