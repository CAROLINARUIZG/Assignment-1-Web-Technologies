<%= link_to "← Users", users_path, class: "text-decoration-none" %>
<h1><%= @user.name %></h1>
<p class="text-muted">
  <%= @user.email %> ·
  <span class="badge bg-<%= @user.admin? ? 'danger' : 'secondary' %>">
    <%= @user.role.titleize %>
  </span>
</p>

<h4 class="mt-4">Organized events (<%= @organized_events.size %>)</h4>
<ul class="list-group mb-3">
  <% @organized_events.each do |e| %>
    <%= link_to e.title, event_path(e), class: "list-group-item list-group-item-action" %>
  <% end %>
</ul>

<h4>Registered to (<%= @registrations.size %>)</h4>
<ul class="list-group mb-3">
  <% @registrations.each do |r| %>
    <li class="list-group-item d-flex justify-content-between">
      <%= link_to r.event.title, event_path(r.event) %>
      <span class="badge bg-info text-dark"><%= r.status.titleize %></span>
    </li>
  <% end %>
</ul>

<h4>Reviews left (<%= @reviews.size %>)</h4>
<ul class="list-group">
  <% @reviews.each do |r| %>
    <li class="list-group-item">
      <strong><%= r.event.title %></strong>: <%= "★" * r.rating %>
      <p class="mb-0 small"><%= r.comment %></p>
    </li>
  <% end %>
</ul>