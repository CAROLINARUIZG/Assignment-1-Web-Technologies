<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Events</h1>
  <% if params[:category_id].present? %>
    <%= link_to "Clear filter", events_path, class: "btn btn-outline-secondary btn-sm" %>
  <% end %>
</div>

<div class="row g-3">
  <% @events.each do |event| %>
    <div class="col-md-6 col-lg-4">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <span class="badge bg-<%= event.published? ? 'success' : 'secondary' %> mb-2">
            <%= event.status.titleize %>
          </span>
          <h5 class="card-title"><%= link_to event.title, event_path(event), class: "text-decoration-none" %></h5>
          <p class="text-muted small mb-1">
            <%= event.category.name %> · <%= event.location.name %>
          </p>
          <p class="small mb-2"><%= event.start_date.strftime("%b %d, %Y %H:%M") %></p>
          <p class="card-text"><%= truncate(event.description.to_s, length: 100) %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>